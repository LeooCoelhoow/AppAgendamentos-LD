{
  "name": "appagendamentos-server",
  "version": "1.0.0",
  "description": "API REST do AppAgendamentos — Express + Prisma + PostgreSQL",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
